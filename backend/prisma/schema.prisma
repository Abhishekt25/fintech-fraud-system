generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model User {
  id                 String        @id @default(uuid())
  name               String
  email              String        @unique
  risk_score         Decimal       @default(0) @db.Decimal(5, 2)
  is_frozen          Boolean       @default(false)
  total_transactions Int           @default(0)
  total_volume       Decimal       @default(0) @db.Decimal(20, 2)
  flagged_count      Int           @default(0)
  blocked_count      Int           @default(0)
  created_at         DateTime      @default(now()) @db.Timestamptz
  updated_at         DateTime      @default(now()) @updatedAt @db.Timestamptz

  transactions       Transaction[]

  @@map("users")
}

model Transaction {
  id               String    @id @default(uuid())
  user_id          String
  amount           Decimal   @db.Decimal(20, 2)
  merchant         String
  category         String?
  country          String?
  device_id        String?
  ip_address       String?
  status           String    @default("PENDING")
  risk_score       Decimal   @default(0) @db.Decimal(5, 2)
  flagged_rules    Json      @default("[]")
  is_duplicate     Boolean   @default(false)
  analyst_override String?
  analyst_note     String?
  created_at       DateTime  @default(now()) @db.Timestamptz
  processed_at     DateTime? @db.Timestamptz

  user             User      @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([status])
  @@index([created_at])
  @@map("transactions")
}

model Rule {
  id          String   @id @default(uuid())
  name        String
  description String?
  priority    Int      @default(50)
  action      String
  weight      Int      @default(10)
  logic       String   @default("AND")
  conditions  Json
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz

  @@index([is_active, priority(sort: Desc)])
  @@map("rules")
}

model AnalystAction {
  id          String   @id @default(uuid())
  analyst_id  String   @default("analyst")
  action_type String
  target_type String
  target_id   String
  details     Json?
  created_at  DateTime @default(now()) @db.Timestamptz

  @@map("analyst_actions")
}